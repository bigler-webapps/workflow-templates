[Unit]
Description=GitHub Actions ephemeral runner — slot %i
# Ephemeral runners exit after one job. Restart=always causes systemd to
# re-launch, which triggers a fresh JIT-config registration (ExecStartPre)
# before the next job pickup. No static registration token remains at rest.
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User={{ github_runner_user }}
Group={{ github_runner_user }}
WorkingDirectory={{ github_runner_base_dir }}/slot-%i

# Private /tmp namespace per service invocation. The JIT-config token written
# by ExecStartPre is invisible to any other process and is destroyed on stop —
# defence in depth on top of the umask 0177 (0600) on the temp file itself.
PrivateTmp=true

# ExecStartPre: obtain a one-time JIT token and write it to a temp file.
# Runner name encodes host + slot for easy identification in the GitHub UI.
ExecStartPre=/bin/bash -c \
  'umask 0177 && {{ github_runner_base_dir }}/bin/jit-config.sh "$(hostname -s)-slot%i" \
   > /tmp/gh-runner-%i.jitconfig'

# ExecStart: launch the runner, reading the JIT token from the temp file.
ExecStart=/bin/bash -c \
  '{{ github_runner_base_dir }}/slot-%i/run.sh \
   --jitconfig "$(cat /tmp/gh-runner-%i.jitconfig)"'

# Remove the one-time token after the runner exits (success or error).
ExecStopPost=/bin/rm -f /tmp/gh-runner-%i.jitconfig

# KillMode=mixed: on stop, systemd sends SIGTERM to the main process and,
# after TimeoutStopSec, SIGKILL to every remaining process in the cgroup.
# With KillMode=process (the previous value) run-helper.sh and
# Runner.Listener were left as orphan processes that stayed registered with
# GitHub, causing HTTP 409 "Already exists" on the next ExecStartPre call.
KillMode=mixed

# Give the runner up to 2 minutes to finish job teardown and deregister
# from GitHub before the SIGKILL fires.
TimeoutStopSec=120

# Restart after each job. RestartSec=30 gives GitHub enough time to
# process the deregistration of the just-used ephemeral identity before
# the next jit-config registration attempt.
Restart=always
RestartSec=30

# Disable the start-limit so transient 409 errors during the deregistration
# window don't put the service into the dead/failed state permanently.
StartLimitIntervalSec=0

# Runners open many file descriptors (git pack objects, Docker layers).
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
