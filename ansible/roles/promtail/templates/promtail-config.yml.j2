# Managed by Ansible role biglerconsult.infra.promtail — do not edit by hand.
# Pushes to Loki via Tailscale — no TLS/auth needed (Tailscale is the trust boundary).

server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/promtail/positions.yaml

clients:
  - url: {{ promtail_loki_url }}

scrape_configs:
  # Scrape all Docker container stdout/stderr via the Docker socket.
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 15s
    relabel_configs:
      # Strip leading slash from container name (e.g. /traefik → traefik).
      - source_labels: [__meta_docker_container_name]
        regex: "/(.*)"
        target_label: container
      # Attach compose project and service for easy filtering in Grafana.
      - source_labels: [__meta_docker_container_label_com_docker_compose_project]
        target_label: compose_project
      - source_labels: [__meta_docker_container_label_com_docker_compose_service]
        target_label: compose_service
      # Preserve stdout vs stderr stream label.
      - source_labels: [__meta_docker_log_stream]
        target_label: stream
      # Tag every log line with the originating host so multi-server queries
      # can filter by host in Grafana.
      - replacement: "{{ inventory_hostname }}"
        target_label: host
{% if promtail_drop_debug %}
    pipeline_stages:
      # Drop DEBUG lines to reduce ingest volume. Disable via promtail_drop_debug=false.
      - drop:
          expression: "(?i)level=debug|\\blevel\\s*:\\s*debug\\b"
          drop_counter_reason: debug_dropped
{% endif %}

  # Scrape OS-level auth events from /var/log/auth.log (login, sudo, sshd, PAM).
  - job_name: auth_log
    static_configs:
      - targets:
          - localhost
        labels:
          job: auth_log
          host: "{{ inventory_hostname }}"
          __path__: /var/log/auth.log
